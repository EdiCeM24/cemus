<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%- title %></title>
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@ionic/core/css/ionic.bundle.css"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Ovo&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Ovo&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="p-0 m-0 box-border w-full h-[100vh]">
    <div
      class="container mx-auto w-full min-h-10 mt-[10%] py-5 px-6 flex items-center justify-center flex-col"
      id="contains"
    >
      <form action="/api/v1/passwords/reset-password/:token" method="POST">
        <h1
          class="mt-3 mb-4 text-white flex text-center justify-center text-xl font-semibold font-serif border-b-2"
        >
          Reset Your Password
        </h1>
        <div
          class="mt-[5%] flex items-center justify-evenly gap-10 mb-10 flex-col w-full"
        >
          <input
            type="password"
            name="password"
            class="w-full p-3 px-3 bg-white border-indigo-400 outline-none rounded-md text-lg font-semibold font-serif text-[#01010f]"
            placeholder="New Password"
            required
            autocomplete="off"
            autofocus
          />

          <input
            type="password"
            name="confirmPassword"
            class="w-full p-3 px-3 bg-white border-indigo-400 outline-none rounded-md text-lg font-semibold font-serif text-[#01010f]"
            placeholder="Confirm New Password"
            required
            autocomplete="off"
            autofocus
          />
        </div>

        <button
          type="submit"
          class="py-3 px-6 w-full text-xl text-white font-serif font-semibold rounded bg-teal-800 hover:bg-teal-700 transition duration-150 ease-in-out border-none"
        >
          Reset Password
        </button>
      </form>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%- title %></title>
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Ovo&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Ovo&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@ionic/core/css/ionic.bundle.css"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-amber-200 p-0 m-0 h-screen">
    <div
      class="container mx-auto p-[10px] mt-[15%] flex items-center justify-center flex-col"
      id="contains"
    >
      <h1
        class="mb-[3%] text-xl font-semibold font-serif border-b-2 text-blue-950"
      >
        Forgot Password Page
      </h1>
      <form
        action="/api/v1/passwords/forgot-password"
        method="POST"
        class="p-[15px] px-[20px] bg-white flex items-center justify-center flex-col shadow-lg mb-3 h-[300px] rounded-md"
      >
        <div
          class="mt-3 mb-[3%] w-full bg-[#eee] flex items-center justify-center flex-col"
        >
          <input
            type="email"
            name="email"
            class="mb-[3%] p-3 px-4 text-[#100114] w-[100%] font-serif font-semibold text-xl rounded-md outline-none border-none bg-amber-100"
            id=""
            placeholder="Enter email to rest password"
            required
            autocomplete="off"
            autofocus
          />

          <button
            type="submit"
            class="py-3 px-10 mt-[20px] w-[100%] sm:w-[100%] sm:text-[20px] mb-5 bg-teal-800 text-white text-xl font-semibold font-serif rounded-md shadow-md hover:bg-teal-700 transition duration-150 ease-in-out border-none"
          >
            Reset with Email
          </button>
        </div>

        <div class="flex items-center justify-evenly gap-6">
          <p
            class="gap-1 flex flex-nowrap whitespace-nowrap items-center justify-center font-medium text-lg"
          >
            Remember Password?
          </p>
          <a
            href="/api/v1/auth/login"
            class="bg-blue-800 w-[80%] hover:bg-sky-600 flex text-center justify-center sm:w-[50%] transition-all duration-150 rounded-md ease-in-out p-1 px-2 font-semibold text-white text-[18px]"
            >Sign In</a
          >
        </div>
      </form>
    </div>
  </body>
</html>

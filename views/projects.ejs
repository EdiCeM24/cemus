<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%- title %></title>

    <link rel="stylesheet" href="/css/output.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Ovo&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Ovo&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@ionic/core/css/ionic.bundle.css"
    />
  </head>
  <body>
    <!-- Navbar -->
    <header
      class="fixed top-0 left-0 w-full z-50 bg-slate-950/80 backdrop-blur-lg border-b border-slate-800"
    >
      <div
        class="max-w-7xl mx-auto px-6 lg:px-12 py-5 flex justify-between items-center"
      >
        <div class="header_myLogo flex items-center justify-evenly gap-1">
          <a
            href="/api/v1/homes/home"
            class="no-underline flex items-center justify-center gap-1"
          >
            <img
              src="/images/favicon3.ico"
              class="w-10 h-10 rounded-full object-cover"
              alt=""
            />
            <h1 class="text-2xl font-extrabold tracking-wide gradient-text">
              EDIDIONG
            </h1>
          </a>
        </div>
        <!-- <h1 class="text-2xl font-extrabold tracking-wide gradient-text">
        EDIDIONG
      </h1> -->

        <nav
          class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-300"
        >
          <a
            href="/api/v1/homes/home#home"
            class="nav-link hover:text-cyan-400 transition ease-in-out hover:border-b-2 border-b-orange-600"
            >Home</a
          >
          <a
            href="/api/v1/homes/about"
            class="nav-link hover:text-cyan-400 transition ease-in-out hover:border-b-2 border-b-orange-600"
            >About</a
          >
          <a
            href="/api/v1/homes/projects"
            class="nav-link hover:text-cyan-400 transition ease-in-out hover:border-b-2 border-b-orange-600"
            >Projects</a
          >
          <a
            href="/api/v1/contacts/contact"
            class="nav-link hover:text-cyan-400 transition ease-in-out hover:border-b-2 border-b-orange-600"
            >Contact</a
          >
          <!-- <a href="#" class="hover:text-cyan-400 transition ease-in-out hover:border-b-2 border-b-orange-600">Services</a> -->
        </nav>

        <button
          class="reach_out_to bg-cyan-500 hover:bg-cyan-400 transition ease-in-out px-5 py-2 rounded-full font-semibold text-slate-950 shadow-lg shadow-cyan-500/30"
        >
          Hire Me
        </button>
      </div>
    </header>

    <div class="contact-conn container mx-auto max-h-screen mt-[4%] p-10 px-10"> 
      <div class="">
        <% if (success_msg) { %>
          <p class="text-green-600 font-serif font-semibold text-[16px]"><%= success_msg[0] %></p>
        <% } %>
      </div>

      <div class="mb-2 p-1">
        <% if (error_msg) { %>
          <span class="text-rose-600 font-serif font-semibold text-[16px]"><%= error_msg %></span>
        <% } %>
      </div>

      <div class="mb-2 p-1">
        <% if(error) { %>
          <span class="text-rose-600 font-serif font-semibold text-[16px]"><%= error %></span>
        <%}%> 
      </div>
    </div>

    <main>
      <h1 class="text-rose-400">Project Page</h1>

      <div class=""></div>

      <!-- Projects -->
      <section id="projects" class="py-28">

        <div class="max-w-7xl mx-auto px-6 lg:px-12">
          
          <a href="/api/v1/homes/home/#projects" id="projects">
            <div class="text-center mb-20">
              <h2 class="text-4xl lg:text-5xl font-extrabold text-white mb-5">
                Featured <span class="gradient-text">Projects</span>
              </h2>

              <p class="text-slate-400 text-lg max-w-2xl mx-auto">
                Some production-level applications and systems I have designed and developed.
              </p>
            </div>
          </a>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

            <div class="glass rounded-3xl overflow-hidden hover:-translate-y-2 transition duration-300">
              <img src="https://images.unsplash.com/photo-1551434678-e076c223a692?q=80&w=1200&auto=format&fit=crop" class="h-56 w-full object-cover" />

              <div class="p-8">
                <h3 class="text-2xl text-white font-bold mb-4">SaaS Dashboard</h3>
                <p class="text-slate-300 mb-6">
                  Analytics and subscription management platform with real-time reports.
                </p>

                <button class="text-cyan-400 font-semibold hover:text-cyan-300">
                  View Project →
                </button>
              </div>
            </div>


            <div class="glass rounded-3xl overflow-hidden hover:-translate-y-2 transition duration-300">
              <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200&auto=format&fit=crop" class="h-56 w-full object-cover" />

              <div class="p-8">
                <h3 class="text-2xl text-white font-bold mb-4">E-Commerce App</h3>
                <p class="text-slate-300 mb-6">
                  Full production ecommerce application with payments and authentication.
                </p>

                <button class="text-cyan-400 font-semibold hover:text-cyan-300">
                  View Project →
                </button>
              </div>
            </div>


            <div class="glass rounded-3xl overflow-hidden hover:-translate-y-2 transition duration-300">
              <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200&auto=format&fit=crop" class="h-56 w-full object-cover" />

              <div class="p-8">
                <h3 class="text-2xl text-white font-bold mb-4">AI Platform</h3>
                <p class="text-slate-300 mb-6">
                  AI powered productivity application with secure backend architecture.
                </p>

                <button class="text-cyan-400 font-semibold hover:text-cyan-300">
                  View Project →
                </button>
              </div>
            </div>

          </div>

        </div>
      </section>
    </main>

    <footer><%- include('partials/footer.ejs') %></footer>
  </body>
</html>
